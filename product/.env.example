# ===========================================================================
# SahuliatAI — Environment Variables Template
#
# Three env files (all gitignored), used by:
#   .env.local    -> pnpm dev    (your laptop, NEXT_PUBLIC_APP_URL=http://localhost:3010)
#   .env.preview  -> pnpm deploy:preview  (Vercel preview deploys)
#   .env.prod     -> pnpm deploy:prod     (Vercel production)
#
# Each one is the FULL set of variables for that environment. Typical
# differences between local and prod:
#   - NEXT_PUBLIC_APP_URL   (localhost vs https://your-prod.vercel.app)
#   - NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY (separate keys with different referer restrictions)
# All other secrets (Supabase, Gemini, VAPID, REMINDERS_FIRE_SECRET) can be
# the same across files if you're using one Supabase project.
#
# Copy this file three times, fill values, never commit:
#   cp .env.example .env.local
#   cp .env.example .env.prod
#   cp .env.example .env.preview
# ===========================================================================

# --- Required: Supabase (provision via Vercel Marketplace) -----------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
# Optional: paste a personal access token here if you don't want to run
# `pnpm exec supabase login` interactively. Generate at
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Direct Postgres connection string — used by db:seed (psql) and any direct SQL.
# Find: Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# Pick "Transaction pooler" and replace [YOUR-PASSWORD] with your DB password.
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Required: Gemini (LLM runtime) ---------------------------------------
# Antigravity IDE is used to *build* agents during development, not at runtime.
# The deployed app calls Gemini directly.
# Get a key from https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=
# Optional model override (defaults to gemini-2.5-flash). Try gemini-1.5-flash
# if 2.5 isn't available in your region.
GEMINI_MODEL=

# --- Required: Google Maps Platform ----------------------------------------
# One key for server, one referer-restricted for browser.
# Enable: Maps JavaScript, Places (New), Geocoding, Distance Matrix
GOOGLE_MAPS_SERVER_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# Toggle to use deterministic fallbacks (no Google API calls). Useful for
# offline dev and protecting demo from quota issues.
NEXT_PUBLIC_USE_GOOGLE_APIS=true

# --- Required: Web Push (VAPID) --------------------------------------------
# Generate with: pnpm vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Required: Reminders endpoint shared secret ----------------------------
# Generate with: openssl rand -hex 32
REMINDERS_FIRE_SECRET=

# --- Required: App URL -----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3010

# --- Optional: Vercel deploy (only for teammates running scripts/deploy.sh) -
# Three options for deploying:
#   1. Skip these — run `pnpm deploy:preview`, the CLI will prompt `vercel login` (browser).
#   2. Headless / shared token — generate at https://vercel.com/account/tokens
#      and paste below. The deploy script auto-uses it (no browser).
#   3. Don't deploy from CLI at all — let Vercel's Git integration deploy on push.
VERCEL_TOKEN=
# Optional: pin the org/project so the script never re-prompts during `vercel link`.
# Find both in .vercel/project.json after the owner runs `vercel link` once,
# or in the Vercel dashboard URL.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- Optional: WhatsApp Cloud API (Meta) -----------------------------------
# If absent, notify_provider falls back to SMS → Mock automatically.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# --- Optional: Twilio SMS --------------------------------------------------
# If absent, notify_provider falls back to Mock.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=


TWA_SHA256_FINGERPRINTS=
